{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for E-Commerce Analytics Dashboard using Express, TypeScript, Prisma, PostgreSQL, Hexagonal Architecture and Data Warehouse (Raw, Clean, Gold layers).",
  "keywords": [
    "keywords:",
    "analytics",
    "ecommerce",
    "dashboard",
    "express",
    "typescript",
    "prisma",
    "postgresql",
    "data-warehouse",
    "etl",
    "hexagonal-architecture",
    "kpi",
    "reporting"
  ],
  "license": "ISC",
  "author": "Fernenri",
  "type": "module",
  "main": "index.js",
"scripts": {
  "test": "vitest run",
  "test:watch": "vitest",
  "dev": "tsx watch src/index.ts",
  "build": "tsc",
  "start": "node dist/index.js",
  "etl": "tsx src/infrastructure/seed/run-etl.ts",
  "prisma:generate": "prisma generate"
},
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
